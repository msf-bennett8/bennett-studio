{
  "identifier": "default",
  "description": "Default capabilities for Bennett Studio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-unmaximize",
    "core:window:allow-unminimize",
    "core:window:allow-start-dragging",
    "core:app:default",
    "core:app:allow-version",
    "core:app:allow-name",
    "core:app:allow-identifier",
    "core:path:default",
    "core:path:allow-resolve",
    "core:path:allow-resolve-directory",
    "core:path:allow-basename",
    "core:path:allow-dirname",
    "core:path:allow-extname",
    "core:path:allow-is-absolute",
    "core:path:allow-join",
    "core:path:allow-normalize",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-internal-toggle-devtools",
    "core:webview:allow-print",
    "core:webview:allow-reparent",
    "core:webview:allow-webview-close",
    "core:webview:allow-webview-show",
    "core:webview:allow-webview-hide",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:image:default"
  ]
}
