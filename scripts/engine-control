#!/bin/bash

PIDFILE="/tmp/bennett-engine.pid"
LOGFILE="/tmp/bennett-engine.log"
BUILD_LOG="/tmp/bennett-engine-build.log"
ENGINE_DIR="/home/msf_bennett/studio.dev/bennett studio"
BINARY="$ENGINE_DIR/target/debug/bennett-engine"

start_engine() {
    # Check if already running
    if [ -f "$PIDFILE" ]; then
        local old_pid=$(cat "$PIDFILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            echo "🔧 Engine already running (PID: $old_pid)"
            exit 0
        fi
    fi

    # Find free port
    local PORT=3001
    for p in 3001 3002 3003 3004 3005 3006 3007 3008 3009 3010; do
        if ! nc -z localhost $p 2>/dev/null; then
            PORT=$p
            break
        fi
    done

    export BENNETT_ENGINE_PORT=$PORT
    echo "$PORT" > /tmp/bennett-engine.port
    cd "$ENGINE_DIR" || exit 1

    # Build first if binary doesn't exist
    if [ ! -x "$BINARY" ]; then
        echo "🔨 Building engine first (this takes ~10 min)..."
        echo "   Build log: $BUILD_LOG"

        # Kill any stale cargo processes holding the lock
        pkill -f "cargo.*bennett" 2>/dev/null || true
        pkill -f "rustc.*bennett" 2>/dev/null || true
        pkill -f "rust-lld" 2>/dev/null || true
        sleep 2

        if ! cargo build --bin bennett-engine 2>&1 | tee "$BUILD_LOG"; then
            echo "❌ BUILD FAILED — check $BUILD_LOG"
            exit 1
        fi
        echo "✅ Build complete"
    fi

    # Start the pre-built binary directly (NOT via cargo run)
    echo "🔧 Starting Bennett Engine on http://0.0.0.0:${PORT}..."
    nohup "$BINARY" > "$LOGFILE" 2>&1 &
    local ENGINE_PID=$!
    echo "$ENGINE_PID" > "$PIDFILE"

    # Wait for health check with progress — INCREASED to 24 minutes
    # because list_bennett_containers() can take 2+ minutes on first start
    echo "⏳ Waiting for engine to be ready (up to 24 minutes)..."
    for i in {1..1440}; do
        if curl -s "http://localhost:$PORT/api/health" > /dev/null 2>&1; then
            echo "✅ Engine ready (PID: $ENGINE_PID, Port: $PORT)"
            return 0
        fi

        if ! kill -0 "$ENGINE_PID" 2>/dev/null; then
            echo "❌ Engine crashed! Check: tail -30 $LOGFILE"
            rm -f "$PIDFILE"
            exit 1
        fi

        # Show progress every 10 seconds, plus milestones
        if [ $((i % 10)) -eq 0 ]; then
            echo "   ... waiting ($i seconds)"
        fi
        if [ $i -eq 300 ]; then
            echo "   ... 5 minutes elapsed, still waiting..."
        fi
        if [ $i -eq 600 ]; then
            echo "   ... 10 minutes elapsed, still waiting..."
        fi
        if [ $i -eq 900 ]; then
            echo "   ... 15 minutes elapsed, still waiting..."
        fi
        if [ $i -eq 1200 ]; then
            echo "   ... 20 minutes elapsed, still waiting..."
        fi
        sleep 1
    done

    echo "⚠️  Engine started but health check not responding yet"
    echo "   Check: tail -f $LOGFILE"
}

stop_engine() {
    echo "🔧 Stopping Engine..."
    
    # Kill by PID file first
    if [ -f "$PIDFILE" ]; then
        local pid=$(cat "$PIDFILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "   Killing PID $pid..."
            kill "$pid" 2>/dev/null
            sleep 1
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
        fi
        rm -f "$PIDFILE"
    fi

    # CRITICAL: Also kill ALL bennett-engine processes (handles orphaned processes)
    local pids=$(pgrep -f "bennett-engine" 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "   Killing orphaned bennett-engine processes: $pids"
        pkill -9 -f "bennett-engine" 2>/dev/null || true
        sleep 1
    fi

    # Kill any cargo processes too
    pkill -f "cargo.*bennett" 2>/dev/null || true
    pkill -f "rustc.*bennett" 2>/dev/null || true
    pkill -f "rust-lld" 2>/dev/null || true
    
    # Wait for processes to actually die
    for i in {1..5}; do
        if ! pgrep -f "bennett-engine" > /dev/null 2>&1; then
            echo "✅ Engine stopped"
            return 0
        fi
        sleep 1
    done
    
    echo "⚠️  Some engine processes may still be running"
}

status_engine() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "🔧 Engine: RUNNING (PID: $(cat $PIDFILE), Port: $(cat /tmp/bennett-engine.port 2>/dev/null || echo 3001))"
    else
        echo "🔧 Engine: STOPPED"
        rm -f "$PIDFILE" 2>/dev/null
    fi
}

clear_engine() {
    rm -f "$LOGFILE" "$BUILD_LOG"
    echo "🔧 Logs cleared"
}

logs_engine() {
    if [ -f "$LOGFILE" ]; then
        tail -f "$LOGFILE"
    else
        echo "🔧 No log file"
    fi
}

case "$1" in
    start)   start_engine ;;
    stop)    stop_engine ;;
    restart) stop_engine; sleep 2; start_engine ;;
    status)  status_engine ;;
    clear)   clear_engine ;;
    logs)    logs_engine ;;
    *)       echo "Usage: $0 {start|stop|restart|status|clear|logs}"; exit 1 ;;
esac
