#!/bin/bash

PIDFILE="/tmp/bennett-web.pid"
LOGFILE="/tmp/bennett-web.log"
WEB_DIR="/home/msf_bennett/studio.dev/bennett studio/web"

start_web() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "🌐 Web already running (PID: $(cat $PIDFILE))"
        exit 0
    fi
    echo "🌐 Starting Web dev server on http://localhost:5173..."
    cd "$WEB_DIR" || exit 1
    nohup npm run dev > "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 3
    echo "🌐 Web started (PID: $(cat $PIDFILE))"
}

stop_web() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "🌐 Stopping Web (PID: $(cat $PIDFILE))..."
        kill $(cat "$PIDFILE") 2>/dev/null
        sleep 1
        pkill -f "vite.*bennett studio/web" 2>/dev/null
        rm -f "$PIDFILE"
        echo "🌐 Web stopped"
    else
        echo "🌐 Web not running"
        rm -f "$PIDFILE"
    fi
}

status_web() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "🌐 Web: RUNNING (PID: $(cat $PIDFILE), Port: 5173)"
    else
        echo "🌐 Web: STOPPED"
        rm -f "$PIDFILE" 2>/dev/null
    fi
}

clear_web() {
    rm -f "$LOGFILE"
    rm -rf "$WEB_DIR/node_modules/.vite"
    rm -rf "$WEB_DIR/node_modules/.cache"
    echo "🌐 Web cache cleared"
}

logs_web() {
    if [ -f "$LOGFILE" ]; then
        tail -f "$LOGFILE"
    else
        echo "🌐 No log file. Start web first."
    fi
}

case "$1" in
    start)   start_web ;;
    stop)    stop_web ;;
    restart) stop_web; sleep 1; start_web ;;
    status)  status_web ;;
    clear)   clear_web ;;
    logs)    logs_web ;;
    *)       echo "Usage: $0 {start|stop|restart|status|clear|logs}"; exit 1 ;;
esac
