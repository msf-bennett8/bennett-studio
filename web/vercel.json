{
  "rewrites": [
    { "source": "/db/:code", "destination": "/index.html" },
    { "source": "/db/:code/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS, PUT, DELETE" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Share-Token" }
      ]
    }
  ]
}
