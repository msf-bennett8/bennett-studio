*.exe
*.dll
*.so
*.dylib

# --- Logs & Temp ---
*.log
*.tmp
*.temp
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials/

# --- Test & Coverage ---
/coverage/
/.nyc_output/
*.lcov

# --- Database ---
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Docker ---
.dockerignore
docker-compose.override.yml

# --- Misc ---
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
**/tsconfig.tsbuildinfo   #

# --- Node.js ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Windows WSL Zone.Identifier files ---
*:Zone.Identifier

